{
  "manifest_version": 3,
  "name": "Roar, kid! — Audiogram EQ for YouTube, Netflix & Prime Video",
  "version": "0.3.0",
  "description": "Audiogram-driven multiband compression for YouTube, Netflix, and Prime Video audio. Prescriptive-style gain (simplified), per ear, with output limiting.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.netflix.com/*",
    "https://www.primevideo.com/*",
    "https://www.amazon.com/gp/video/*",
    "https://www.amazon.com/Amazon-Video/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.x.ai/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.netflix.com/*",
        "https://www.primevideo.com/*",
        "https://www.amazon.com/gp/video/*",
        "https://www.amazon.com/Amazon-Video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Roar, kid! audiogram",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
